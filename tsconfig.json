{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "lib": ["ES2022"],
    "types": ["node", "vitest/globals"],
    "paths": {
      "@/*": ["apps/api/src/*"],
      "@server": ["apps/api/src"],
      "@server/*": ["apps/api/src/*"],
      "@mcp": ["apps/mcp-server/src"],
      "@mcp/*": ["apps/mcp-server/src/*"],
      "@tests": ["tests"],
      "@tests/*": ["tests/*"]
    }
  },
  "include": [
    "tests/**/*.ts",
    "vitest.config.ts",
    "vitest.integration.config.ts",
    "vitest.mcp.config.ts",
    "vitest.workspace.ts",
    "orval.config.ts"
  ],
  "exclude": ["node_modules", "dist", "build", ".next", "apps/web"]
}
