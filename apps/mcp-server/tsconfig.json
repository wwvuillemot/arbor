{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "lib": ["ES2022"],
    "types": ["node"],
    "paths": {
      "@mcp": ["src"],
      "@mcp/*": ["src/*"],
      "@server": ["../api/src"],
      "@server/*": ["../api/src/*"],
      "@tests": ["../../tests"],
      "@tests/*": ["../../tests/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "coverage"]
}
